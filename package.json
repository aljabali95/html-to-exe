{
  "name": "express-wash-erp",
  "version": "1.0.0",
  "description": "مغسلة الاكسبريس — نظام إدارة متكامل",
  "author": "AL JABALI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.expresswash.erp",
    "productName": "مغسلة الاكسبريس",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "extraResources": [
      { "from": "mediamtx.yml", "to": "mediamtx.yml" }
    ],
    "files": [
      "main.js",
      "index.html",
      "manifest.json",
      "sw.js",
      "icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
