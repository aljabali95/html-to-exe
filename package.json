{
  "name": "express-wash-erp",
  "version": "6.0.1",
  "description": "مغسلة الاكسبريس — نظام إدارة متكامل",
  "author": "AL JABALI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.expresswash.erp",
    "productName": "ExpressWash",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "extraResources": [
      { "from": "mediamtx.exe", "to": "mediamtx.exe" },
      { "from": "mediamtx.yml", "to": "mediamtx.yml" },
      { "from": "index.html", "to": "index.html" }
    ],
    "files": [
      "main.js",
      "icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
